{"channel": "C04QBRY1P34", "text": "Report App — weekly pulse", "blocks": [{"type": "rich_text", "elements": [{"type": "rich_text_section", "elements": [{"type": "text", "text": "REPORT APP — WEEKLY PULSE", "style": {"bold": true}}, {"type": "text", "text": "\nWeek of May 4–10, 2026"}]}, {"type": "rich_text_section", "elements": [{"type": "text", "text": "\n"}, {"type": "text", "text": "Usage", "style": {"bold": true}}, {"type": "text", "text": " — report opens as a % of hosting sessions in the week. Δ = WoW change."}]}, {"type": "rich_text_list", "style": "bullet", "elements": [{"type": "rich_text_section", "elements": [{"type": "text", "text": "Top: "}, {"type": "text", "text": "Presentation Report", "style": {"bold": true}}, {"type": "text", "text": " 95.3% (+3.7%), "}, {"type": "text", "text": "Sessions Report", "style": {"bold": true}}, {"type": "text", "text": " 32.6% (flat), "}, {"type": "text", "text": "Presentation Report > Participant Report", "style": {"bold": true}}, {"type": "text", "text": " 13.1% (-6.8%; also down from a ~27% Feb–Mar average)."}]}, {"type": "rich_text_section", "elements": [{"type": "text", "text": "Risers WoW: All Participant Responses 3.3% (+94%), All Participants 4.6% (+50%), Shared Presentation 2.8% (+24%), All Slides 3.5% (+13%). The newer report pages are all picking up."}]}, {"type": "rich_text_section", "elements": [{"type": "text", "text": "💀 Long-term fader: "}, {"type": "text", "text": "Presentation Report > Feedback Tab", "style": {"bold": true}}, {"type": "text", "text": " sitting at 0.24%, down from ~4.9% before mid-April. Five straight weeks under 1% — something broke or moved."}]}]}, {"type": "rich_text_section", "elements": [{"type": "text", "text": "\n"}, {"type": "text", "text": "CSAT", "style": {"bold": true}}, {"type": "text", "text": " (all-time, n ≥ 10 votes)"}]}, {"type": "rich_text_list", "style": "bullet", "elements": [{"type": "rich_text_section", "elements": [{"type": "text", "text": "Top: "}, {"type": "tex